BOT_TOKEN=123456:telegram_bot_token
AI_API_KEY=your_openai_compatible_key
AI_BASE_URL=https://api.openai.com/v1
AI_TEXT_MODEL=gpt-4o
AI_TRANSCRIBE_MODEL=whisper-1

MASTERS_CHAT_ID=-1001234567890
MASTER_TELEGRAM_IDS=111111111,222222222
ADMIN_TELEGRAM_IDS=333333333

POSTGRES_DB=scooter_service
POSTGRES_USER=scooter_user
POSTGRES_PASSWORD=change_me
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://scooter_user:change_me@postgres:5432/scooter_service

REDIS_URL=redis://redis:6379/0
RUN_MIGRATIONS_ON_STARTUP=true

STORAGE_DIR=storage
MEDIA_GROUP_WAIT_SECONDS=2.0
MAX_PHOTOS_PER_TICKET=8
MAX_VOICE_SIZE_MB=20
RATE_LIMIT_PER_MINUTE=20

# Release 1.2 calendar / observability
SERVICE_TIMEZONE=Europe/Bucharest
WORKDAY_START_HOUR=10
WORKDAY_END_HOUR=19
WORKDAY_NUMBERS=0,1,2,3,4,5
SLOT_DURATION_MINUTES=120
SLOT_SEARCH_DAYS=14
STALE_TICKET_MINUTES=30
OBSERVABILITY_ENABLED=true
HEALTH_HOST=0.0.0.0
HEALTH_PORT=8080

# Optional S3/MinIO media storage. Keep STORAGE_BACKEND=local for simple deploy.
STORAGE_BACKEND=local
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin123
S3_BUCKET=scooter-service-media
S3_REGION=us-east-1
S3_PUBLIC_BASE_URL=
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
